    transition: all 0.2s;
  }

  .btn-secondary {
    background: #f5f5f5;
    color: #333;
  }

  .btn-secondary:hover {
    background: #e8e8e8;
  }

  /* Version History Section */
  .version-history-section {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .version-history-section h2 {
    font-size: 1.25rem;
    color: #1a1a2e;
    margin: 0 0 1rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .version-history {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .version-entry {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
  }

  .version-entry.latest {
    border-color: #4a90d9;
    background: #f0f7ff;
  }

  .version-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .version-number {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .version-number a {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a2e;
    text-decoration: none;
  }

  .version-number a:hover {
    color: #4a90d9;
  }

  .latest-badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    background: #4a90d9;
    color: white;
    border-radius: 4px;
    font-weight: 500;
  }

  .version-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: #666;
  }

  .version-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-small {
    padding: 0.4rem 0.8rem;
    font-size: 0.875rem;
  }

  /* Sample Section */
  .sample-section {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .sample-section h2 {
    font-size: 1.25rem;
    color: #1a1a2e;
    margin: 0 0 0.5rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .sample-description {
