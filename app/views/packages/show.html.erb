<% content_for :title, "#{@package.name} - DragonRuby Forge" %>

<div class="package-detail-container">
  <nav class="breadcrumb">
    <a href="/">All Packages</a>
    <span class="separator">/</span>
    <a href="/packages/<%= @package.name %>"><%= @package.name %></a>
    <span class="separator">/</span>
    <span class="current">Source</span>
  </nav>

  <header class="package-header">
    <div class="package-title">
      <h1><%= @package.name %></h1>
      <form action="/packages/<%= @package.name %>" method="get" class="version-selector">
        <select name="version" onchange="this.form.submit()">
          <option value="<%= @package.latest_version %>" <%= @selected_version == @package.latest_version ? 'selected' : '' %>>
            <%= @package.latest_version %> (latest)
          </option>
          <% @package.versions.order(version: :desc).each do |v| %>
            <% next if v.version == @package.latest_version %>
            <option value="<%= v.version %>" <%= @selected_version == v.version ? 'selected' : '' %>>
              <%= v.version %>
            </option>
          <% end %>
        </select>
      </form>
    </div>
    <p class="description"><%= @package.description %></p>
    <div class="meta">
      <span class="author">by <%= @package.author %></span>
    </div>
  </header>

  <div class="package-content">
    <section class="info-section">
      <h2>Details</h2>

      <div class="info-row">
        <span class="label">DragonRuby Version:</span>
        <span class="value"><%= @version.dragonruby_version %></span>
      </div>

      <% if @version.dependencies && @version.dependencies.any? %>
        <div class="info-row">
          <span class="label">Dependencies:</span>
          <div class="value">
            <% @version.dependencies.each do |dep, version| %>
              <span class="dependency"><%= dep %> (<%= version %>)</span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @version.scripts && @version.scripts.any? %>
        <div class="info-row">
          <span class="label">Scripts:</span>
          <div class="value">
            <% @version.scripts.each do |script| %>
              <span class="script"><%= script %></span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @version.tags && @version.tags.any? %>
        <div class="info-row">
          <span class="label">Tags:</span>
          <div class="tags">
            <% @version.tags.each do |tag| %>
              <a href="/?tag=<%= tag %>" class="tag"><%= tag %></a>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>

    <section class="install-section">
      <h2>Installation</h2>
      <div class="install-command">
        <code>Forge.add_package("<%= @package.name %>")</code>
      </div>
      <p class="install-note">Paste this in your game or run it in the DragonRuby console.</p>
      <button class="btn btn-primary copy-btn" onclick="copyInstallCommand()">Copy</button>
    </section>

    <% if @samples && @samples.any? %>
    <section class="sample-section">
      <h2>Try Sample</h2>
      <p class="sample-description">Preview this package directly in your browser.</p>
      <div class="sample-selector">
        <label for="sample-select">Choose a sample:</label>
        <select id="sample-select" onchange="updateSamplePreview()">
          <% @samples.each do |sample| %>
            <option value="<%= sample %>"><%= sample %></option>
          <% end %>
        </select>
      </div>
      <button id="try-sample-btn" class="btn btn-primary" onclick="trySample()">
        ▶ Try Sample
      </button>
      <div id="sample-preview" class="sample-preview" style="display: none;">
        <div class="sample-header">
          <span class="sample-title"></span>
          <button class="close-sample" onclick="closeSample()">×</button>
        </div>
        <iframe id="sample-iframe" class="sample-iframe" src=""></iframe>
      </div>
    </section>
    <% end %>
  </div>

  <section class="code-section">
    <h2>Source Code</h2>
    <p class="code-description">Browse and read the full source code before installing.</p>

    <div class="code-browser">
      <div class="file-tree">
        <%= turbo_frame_tag "file-tree", src: package_files_path(@package.name, version: @selected_version) do %>
          <p>Loading files...</p>
        <% end %>
      </div>

      <div class="code-viewer">
        <%= turbo_frame_tag "file-content", src: package_file_content_path(@package.name, "manifest.json", version: @selected_version) do %>
          <div class="code-header">
            <span class="filename">manifest.json</span>
            <span class="language">JSON</span>
          </div>
          <pre class="code-content"><code>Loading...</code></pre>
        <% end %>
      </div>
    </div>
  </section>

  <% if @package.versions.count > 1 %>
  <section class="version-history-section">
    <h2>Version History</h2>
    <div class="version-history">
      <% @package.versions.order(version: :desc).each do |v| %>
        <div class="version-entry <%= v.version == @package.latest_version ? 'latest' : '' %>">
          <div class="version-info">
            <div class="version-number">
              <a href="<%= package_path(@package.name, version: v.version) %>">v<%= v.version %></a>
              <% if v.version == @package.latest_version %>
                <span class="latest-badge">latest</span>
              <% end %>
            </div>
            <div class="version-meta">
              <span class="version-date"><%= v.created_at.strftime("%B %d, %Y") %></span>
              <span class="version-author">by <%= @package.author %></span>
            </div>
          </div>
          <div class="version-actions">
            <a href="<%= package_path(@package.name, version: v.version) %>" class="btn btn-small">View</a>
          </div>
        </div>
      <% end %>
    </div>
  </section>
  <% elsif @package.versions.count == 1 && @package.versions.first.version != @package.latest_version %>
  <section class="version-history-section">
    <h2>Version History</h2>
    <div class="version-history">
      <div class="version-entry latest">
        <div class="version-info">
          <div class="version-number">
            <a href="<%= package_path(@package.name, version: @package.latest_version) %>">v<%= @package.latest_version %></a>
            <span class="latest-badge">latest</span>
          </div>
          <div class="version-meta">
            <span class="version-date"><%= @package.updated_at.strftime("%B %d, %Y") %></span>
            <span class="version-author">by <%= @package.author %></span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <% end %>

  <div class="package-actions">
    <a href="/" class="btn btn-secondary">← Back to Packages</a>
  </div>
</div>

<style>
