  .file-link.active { background: #dbeafe; color: #2563eb; }
  .file-icon { font-size: 0.9rem; }
  .folder-label {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
    font-weight: 500;
    user-select: none;
    padding: 0.2rem 0;
    font-size: 0.875rem;
    color: #555;
  }
  .folder-arrow { font-size: 0.6rem; transition: transform 0.15s; }
  .folder-contents { display: none; padding-left: 1rem; list-style: none; margin: 0; }
  .folder.open > .folder-contents { display: block; }
  .folder.open > .folder-label > .folder-arrow { transform: rotate(90deg); }
  .file-tree ul { list-style: none; padding: 0; margin: 0; }
  .file-tree li { padding: 0.1rem 0; }

  /* Syntax highlighting */
  .code-content .keyword { color: #cba6f7; }
  .code-content .string { color: #a6e3a1; }
  .code-content .number { color: #fab387; }
  .code-content .comment { color: #6c7086; font-style: italic; }
  .code-content .constant { color: #f9e2af; }
  .code-content .symbol { color: #f5c2e7; }
  .code-content .variable { color: #94e2d5; }
  .code-content .def { color: #89b4fa; }
  .code-content .class { color: #f9e2af; }
  .code-content .json-key { color: #89b4fa; }
  .code-content .json-string { color: #a6e3a1; }
  .code-content .json-number { color: #fab387; }
  .code-content .json-bool { color: #f38ba8; }
  .code-content .json-null { color: #6c7086; }
  .code-content .json-punct { color: #cdd6f4; }

  /* Turbo frame loading */
  turbo-frame:not([src]) .code-header,
  turbo-frame[loading] { display: block; opacity: 0.6; }
</style>

<script>
  // Sample preview functionality  // Sample preview functionality
  const samplePackageName = '<%= @package.name %>';
  let currentBackendUrl = '<%= ENV["FORGE_BACKEND_URL"] || "http://localhost:3000" %>';

  function updateSamplePreview() {
    // Could update preview thumbnail here
  }

  async function trySample() {
    const sampleSelect = document.getElementById('sample-select');
    const sampleName = sampleSelect.value;
    const preview = document.getElementById('sample-preview');
    const iframe = document.getElementById('sample-iframe');
    const title = preview.querySelector('.sample-title');

    // Show loading state
    title.textContent = `Loading ${sampleName}...`;
    preview.style.display = 'block';

    try {
      // Fetch sample main.rb content
      const response = await fetch(`${currentBackendUrl}/api/packages/${samplePackageName}/samples/${sampleName}`);
      const data = await response.json();

      if (data.error) {
        title.textContent = `Error: ${data.error}`;
        return;
      }

      // For now, we'll show a message since we can't run DragonRuby in the browser
      // In the future, this would dynamically create a game structure
      title.textContent = `${sampleName} - ${samplePackageName}`;

      // Create a simple demo since we can't run actual DragonRuby
      // The actual implementation would use an embed like postcarts did
      iframe.srcdoc = `
        <!DOCTYPE html>
        <html>
        <head>
          <style>
            body {
              margin: 0;
              background: #1a1a2e;
              color: #e0e0e0;
              font-family: 'Courier New', monospace;
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: center;
              height: 100vh;
            }
            h1 { color: #4a90d9; margin-bottom: 1rem; }
            p { color: #888; max-width: 400px; text-align: center; }
            code {
              background: #2a2a3e;
              padding: 0.5rem 1rem;
              border-radius: 4px;
              display: block;
              margin-top: 1rem;
              white-space: pre-wrap;
              font-size: 0.8rem;
            }
          </style>
        </head>
        <body>
          <h1>${sampleName}</h1>
          <p>This sample is available in the package. To run it:</p>
          <code>forge install ${samplePackageName}
# Copy the sample to your project
# Run: ./dragonruby .</code>
        </body>
        </html>
      `;
    } catch (error) {
      title.textContent = `Error: ${error.message}`;
    }
  }

  function closeSample() {
    const preview = document.getElementById('sample-preview');
    preview.style.display = 'none';
  }
</script>

