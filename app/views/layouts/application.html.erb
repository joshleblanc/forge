<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dragonruby Forge" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Dragonruby Forge">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      .site-header {
        background: #1a1a2e;
        padding: 1rem 2rem;
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .header-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        color: white;
        text-decoration: none;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .user-greeting {
        color: #aaa;
        font-size: 0.875rem;
      }

      .btn {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
      }

      .btn-primary {
        background: #4a90d9;
        color: white;
      }

      .btn-primary:hover {
        background: #357abd;
      }

      .btn-outline {
        background: transparent;
        color: white;
        border: 1px solid rgba(255,255,255,0.3);
      }

      .btn-outline:hover {
        border-color: white;
      }

      .notice, .alert {
        padding: 0.75rem 1rem;
        margin: 1rem 2rem;
        border-radius: 6px;
        font-size: 0.875rem;
      }

      .notice {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
      }

      .alert {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-content">
        <a href="/" class="logo">DragonRuby Forge</a>
        <nav class="nav-links">
          <%= link_to "New Game", "/new", class: "btn btn-primary" %>
          <% if logged_in? %>
            <%= link_to "Publish", packages_publish_path, class: "btn btn-outline" %>
            <%= link_to "Settings", settings_path, class: "btn btn-outline" %>
            <span class="user-greeting">Hello, <%= current_user.username %></span>
            <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline" %>
          <% else %>
            <%= link_to "Login", login_path, class: "btn btn-outline" %>
            <%= link_to "Register", register_path, class: "btn btn-outline" %>
          <% end %>
        </nav>
      </div>
    </header>

    <% if notice %>
      <div class="notice"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="alert"><%= alert %></div>
    <% end %>

    <%= yield %>
  </body>
</html>
